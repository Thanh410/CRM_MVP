# ============================================================
# CRM MVP – Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ---- App ----
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# ---- Dev Demo Accounts (web app login hint) ----
# Chỉ set khi local dev. NEVER set NEXT_PUBLIC_DEMO_* trong production.
# Seed credentials: xem apps/api/prisma/seed.ts
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=

# ---- Database ----
# Production: dùng password mạnh + connection_limit
# Generate: openssl rand -hex 32
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=
POSTGRES_DB=crm_db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://crm_user:CHANGE_ME@localhost:5432/crm_db?schema=public&connection_limit=20&pool_timeout=20"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
# REQUIRED in production. Min 32 chars, must be different.
# Generate each: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES=7d

# ---- MinIO / S3 ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=crm-files
S3_REGION=us-east-1
S3_USE_SSL=false

# ---- pgAdmin ----
PGADMIN_EMAIL=admin@crm.local
PGADMIN_PASSWORD=pgadmin_change_me

# ---- Throttle ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- Logging ----
LOG_LEVEL=info
LOG_PRETTY=true

# ---- Encryption (AES-256-GCM cho channel credentials) ----
# REQUIRED in production. Phải là 32-byte key.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ---- Zalo OA ----
ZALO_OA_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_WEBHOOK_SECRET=

# ---- Facebook Messenger ----
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=
