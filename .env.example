# ============================================================
# CRM MVP – Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ---- App ----
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# ---- Dev Demo Accounts (web app login hint, dev only) ----
NEXT_PUBLIC_DEMO_EMAIL=superadmin@abc.com.vn
NEXT_PUBLIC_DEMO_PASSWORD=Admin@123456

# ---- Database ----
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password_change_me
POSTGRES_DB=crm_db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://crm_user:crm_password_change_me@localhost:5432/crm_db?schema=public"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=super_secret_change_me_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=refresh_secret_change_me_in_production_min_32_chars
JWT_REFRESH_EXPIRES=7d

# ---- MinIO / S3 ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=crm-files
S3_REGION=us-east-1
S3_USE_SSL=false

# ---- pgAdmin ----
PGADMIN_EMAIL=admin@crm.local
PGADMIN_PASSWORD=pgadmin_change_me

# ---- Throttle ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- Logging ----
LOG_LEVEL=info
LOG_PRETTY=true

# ---- Encryption (for channel credentials) ----
ENCRYPTION_KEY=32_char_hex_key_change_me_in_prod

# ---- Zalo OA ----
ZALO_OA_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_WEBHOOK_SECRET=

# ---- Facebook Messenger ----
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=
